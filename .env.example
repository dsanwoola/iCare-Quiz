# Firebase web config (public identifiers — safe to expose; access is controlled
# by Firestore/Storage Security Rules and App Check). These already have sane
# defaults baked into src/react-app/lib/firebase.ts, so overriding is optional.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check reCAPTCHA Enterprise site key (public identifier).
VITE_RECAPTCHA_KEY=

# LOCAL DEV ONLY — App Check debug token so localhost isn't blocked.
# Put the real value in .env.local (which is gitignored). Never commit it.
VITE_APPCHECK_DEBUG_TOKEN=
