rules_version = '2';

// Storage rules for quiz logos.
// Logos are displayed to players (including anonymous ones) in the lobby and
// during play, so reads are public. Writes are restricted to the authenticated
// owner's own folder and limited to reasonably-sized image files.
service firebase.storage {
  match /b/{bucket}/o {
    match /quiz-logos/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
